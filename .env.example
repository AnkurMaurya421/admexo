# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=Team <onboarding@yourdomain.com>

# Used to build absolute tracking URLs inside the email
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Where the "Learn more" link should ultimately point
LEARN_MORE_URL=https://admexo.com

# OpenAI (bonus AI lead classification — optional)
# If unset, classification falls back to the instant rule-based classifier.
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
