# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Gmail SMTP (sends to ANY recipient immediately — no domain verification needed)
# Setup:
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Generate an App Password: https://myaccount.google.com/apppasswords
#      (App: Mail, Device: Other — name it "LeadTracker")
#   3. Paste the 16-character password below (spaces are fine, Nodemailer handles it)
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
FROM_NAME=OntoWeb

# Used to build absolute tracking URLs inside the email
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Where the "Learn more" link should ultimately point
LEARN_MORE_URL=https://admexo.com

# OpenAI (bonus AI lead classification — optional)
# If unset, classification falls back to the instant rule-based classifier.
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
